<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Invex_App.LoginViews.ForgotPassword"
             NavigationPage.HasNavigationBar="False">
    <Grid>
        <Image x:Name="BackgroundImage" Source="inventario.png" Aspect="AspectFill" />

        <BoxView x:Name="DarkOverlay" Color="Black" Opacity="0.5" />

        <ImageButton x:Name="ThemeToggleButton"
             Source="{AppThemeBinding Light=luna_simbolo.png, Dark=sol_simbolo.png}" 
             HorizontalOptions="Start"
             VerticalOptions="Start"
             HeightRequest="40"
             WidthRequest="40"
             Margin="20"
             Clicked="OnThemeToggleButtonClicked"
             ZIndex="5" />

        <ScrollView>

            <VerticalStackLayout Spacing="20" Padding="40" VerticalOptions="Center">

                <Label Text="ANTHIVE STOCK" TextColor="{DynamicResource AppTextColor}"  FontSize="45" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Gestión Inteligente de Stock" TextColor="{DynamicResource AppSubTitleColor}"  FontSize="16" HorizontalOptions="Center" Margin="0,0,0,30"/>

                <VerticalStackLayout x:Name="OlvidasteContraseñaFormContainer" Spacing="15" Padding="40" VerticalOptions="Center">

                    <Label Text="Ingresa tu correo electronico para mandarte más información"
                       HorizontalOptions="Center"
                       TextColor="{DynamicResource AppTextColor}" 
                       HeightRequest="25"/>

                    <Entry Placeholder="Correo electrónico" 
                       PlaceholderColor="{DynamicResource AppSubTitleColor}" 
                       TextColor="{DynamicResource AppEntryTextColor}"
                       HeightRequest="50"/>

                    <Button Text="ENVIAR"
                        TextColor="White"
                        BackgroundColor="#1A56A6"                         
                        HeightRequest="55" 
                        CornerRadius="28"
                        Clicked="OnRecuperarContraseñaClicked"/>

                    <Button Text="Volver" 
                        TextColor="{DynamicResource AppTextColor}" 
                        BackgroundColor="Transparent" 
                        Clicked="OnBackClicked"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>