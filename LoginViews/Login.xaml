<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Invex_App.LoginViews.Login"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Image x:Name="BackgroundImage" Source="inventario.png" Aspect="AspectFill" />
        <BoxView x:Name="DarkOverlay" Color="Black" Opacity="0.5" />

        <ImageButton x:Name="ThemeToggleButton"
                     Source="sol_simbolo.png" 
                     HorizontalOptions="Start"
                     VerticalOptions="Start"
                     HeightRequest="40"
                     WidthRequest="40"
                     Margin="20"
                     Clicked="OnThemeToggleButtonClicked"
                     ZIndex="1" />

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="40" VerticalOptions="Center">
                <Label Text="ANTHIVE STOCK" 
                       TextColor="{DynamicResource AppTextColor}" 
                       FontSize="45" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Gestión Inteligente de inventario" 
                       TextColor="{DynamicResource AppSubTitleColor}" 
                       FontSize="16" HorizontalOptions="Center" Margin="0,0,0,30"/>

                <VerticalStackLayout x:Name="InitialButtonsContainer" Spacing="20">
                    <Button Text="INICIAR SESIÓN" BackgroundColor="#1A56A6" TextColor="White" 
                            HeightRequest="55" CornerRadius="28" Clicked="OnLoginClicked"/>

                    <Button Text="CREAR CUENTA" 
                            BackgroundColor="Transparent" 
                            BorderColor="{DynamicResource AppButtonBorder}"
                            BorderWidth="2"
                            TextColor="{DynamicResource AppTextColor}" 
                            HeightRequest="55" CornerRadius="28" Clicked="OnCreateAccountClicked"/>

                    <Border StrokeShape="RoundRectangle 28" BackgroundColor="White" HeightRequest="55">
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                            <Image Source="google.png" HeightRequest="25" VerticalOptions="Center"/>
                            <Label Text="Continuar con Google" TextColor="#444" VerticalOptions="Center" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGoogleLoginTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>