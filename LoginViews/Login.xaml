<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Invex_App.LoginViews.Login"
             NavigationPage.HasNavigationBar="False"
             Shell.FlyoutBehavior="Disabled">

    <Grid>
        <Image Source="inventario.png" Aspect="AspectFill" />
        <BoxView Color="Black" Opacity="0.5" />



        <VerticalStackLayout Spacing="20" Padding="40" VerticalOptions="Center">

            <Label Text="ANTHIVE STOCK" TextColor="White" FontSize="45" FontAttributes="Bold" HorizontalOptions="Center"/>
            <Label Text="Gestión Inteligente de Stock" TextColor="#D1D1D1" FontSize="16" HorizontalOptions="Center" Margin="0,0,0,30"/>

            <VerticalStackLayout x:Name="InitialButtonsContainer" Spacing="20" IsVisible="True">

                <Button Text="INICIAR SESIÓN" 
                        BackgroundColor="#1A56A6" 
                        TextColor="White" 
                        HeightRequest="55" 
                        CornerRadius="28"
                        Clicked="OnLoginClicked"/>

                <Button Text="CREAR CUENTA" 
                        BackgroundColor="Transparent" 
                        BorderColor="White"
                        BorderWidth="2"
                        TextColor="White" 
                        HeightRequest="55" 
                        CornerRadius="28"
                        Clicked="OnCreateAccountClicked"/>

                <Border StrokeShape="RoundRectangle 28" BackgroundColor="White" HeightRequest="55">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                        <Image Source="google.png" HeightRequest="25" VerticalOptions="Center"/>
                        <Label Text="Continuar con Google" TextColor="#444" VerticalOptions="Center" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoogleLoginTapped" />
                    </Border.GestureRecognizers>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>

    </Grid>
</ContentPage>