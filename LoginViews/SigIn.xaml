<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AntHiveStock.LoginViews.SigIn"
             NavigationPage.HasNavigationBar="False">
    <Grid>
        <Image x:Name="BackgroundImage" Source="inventario.png" Aspect="AspectFill" />
        <BoxView x:Name="DarkOverlay" Color="Black" Opacity="0.5" />

        <ImageButton x:Name="ThemeToggleButton"
             Source="{AppThemeBinding Light=luna_simbolo.png, Dark=sol_simbolo.png}" 
             HorizontalOptions="Start"
             VerticalOptions="Start"
             HeightRequest="40"
             WidthRequest="40"
             Margin="20"
             Clicked="OnThemeToggleButtonClicked"
             ZIndex="5" />

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="40" VerticalOptions="Center">
                <Label Text="ANTHIVE STOCK" TextColor="{DynamicResource AppTextColor}" FontSize="45" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Gestión Inteligente de inventario" TextColor="{DynamicResource AppSubTitleColor}" FontSize="16" HorizontalOptions="Center" Margin="0,0,0,30"/>

                <VerticalStackLayout x:Name="LoginFormContainer" Spacing="15">
                    <Entry x:Name="TxtEmail" Placeholder="Correo electrónico" PlaceholderColor="{DynamicResource AppSubTitleColor}" TextColor="{DynamicResource AppEntryTextColor}" HeightRequest="50"/>
                    <Label x:Name="ErrorEmail" Text="Por favor ingrese su correo electrónico" TextColor="Red" FontSize="13" IsVisible="False" Margin="5,-10,0,0"/>

                    <Grid ColumnDefinitions="*, auto">
                        <Entry x:Name="LoginPasswordEntry" Placeholder="Contraseña" PlaceholderColor="{DynamicResource AppSubTitleColor}" TextColor="{DynamicResource AppEntryTextColor}" IsPassword="True" HeightRequest="50"/>
                        <ImageButton x:Name="ToggleLoginPasswordButton" Grid.Column="1" Source="ojo_cerrado.png" HeightRequest="25" WidthRequest="25" VerticalOptions="Center" Margin="-40,0,10,0" Clicked="OnLoginPasswordClicked"/>
                    </Grid>
                    <Label x:Name="ErrorPassword" Text="Por favor ingrese su contraseña" TextColor="Red" FontSize="13" IsVisible="False" Margin="5,0,0,0"/>

                    <Button Text="INGRESAR" BackgroundColor="#1A56A6" TextColor="White" HeightRequest="55" CornerRadius="28" Clicked="OnSubmitLoginClicked"/>
                    <Button Text="Volver" TextColor="{DynamicResource AppTextColor}" BackgroundColor="Transparent" Clicked="OnBackClicked"/>
                    <Button Text="¿Olvidaste la contraseña?" BackgroundColor="Transparent" TextColor="{DynamicResource AppTextColor}" HeightRequest="26" CornerRadius="28" Margin="0,10" HorizontalOptions="Center" Clicked="OnOlvidasteContraseñaClicked"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>