<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Invex_App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Invex_App"

    xmlns:views="clr-namespace:Invex_App.Views"
    Title="Invex_App"
    xmlns:login="clr-namespace:Invex_App.LoginViews"
    FlyoutBehavior="Flyout">


    <!-- ENCABEZADO DEL MENÚ -->
    <Shell.FlyoutHeader>
        <VerticalStackLayout Padding="20" BackgroundColor="{StaticResource Primary}">
            <Label Text="ANTHIVE STOCK"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"/>
        </VerticalStackLayout>
    </Shell.FlyoutHeader>
    

    <!-- MENÚ LATERAL -->

    <FlyoutItem Title="Dashboard" Icon="dashboard.png">
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="DashboardPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Acerca de" Icon="Info.png">
        <ShellContent
            Title="Acerca de"
            ContentTemplate="{DataTemplate views:AboutPage}"
            Route="AboutPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Configuración" Icon="settings.png">
        <ShellContent
            Title="Configuración"
            ContentTemplate="{DataTemplate views:SettingPage}"
            Route="SettingPage"/>
    </FlyoutItem>

    <MenuItem 
        Text="Cerrar Sesión"
        IconImageSource="logout.png"
        Clicked="OnLogoutClicked"/>

    xmlns:login="clr-namespace:Invex_App.LoginViews"
    xmlns:views="clr-namespace:Invex_App.Views"
    Title="Invex_App"
    FlyoutBehavior="Disabled">
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate login:Login}"
        Route="LoginPage" />

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate views:DashboardPage}"
        Route="DashboardPage" />


</Shell>