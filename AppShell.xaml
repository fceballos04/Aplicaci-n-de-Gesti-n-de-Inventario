<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Invex_App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:login="clr-namespace:Invex_App.LoginViews"
    xmlns:views="clr-namespace:Invex_App.Views"
    Title="Invex_App"
    FlyoutBehavior="Flyout"
    Shell.FlyoutBackgroundColor="#F5F6FA">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate login:Login}"
        Route="LoginPage"
        FlyoutItemIsVisible="False" />

    <FlyoutItem Title="Panel de Inicio" Icon="home_icon.png">
        <ShellContent 
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="DashboardPage" />
    </FlyoutItem>

    <FlyoutItem Title="Mi Inventario" Icon="box_icon.png">
        <ShellContent 
            ContentTemplate="{DataTemplate views:DashboardPage}" />
    </FlyoutItem>

</Shell>