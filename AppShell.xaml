<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Invex_App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Invex_App"
    xmlns:login="clr-namespace:Invex_App.LoginViews"
    xmlns:views="clr-namespace:Invex_App.Views"
    Title="Invex_App"
    FlyoutBehavior="Disabled">
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate login:Login}"
        Route="LoginPage" />

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate views:DashboardPage}"
        Route="DashboardPage" />

</Shell>