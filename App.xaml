<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Invex_App"
             x:Class="Invex_App.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="AppTextColor">White</Color>
            <Color x:Key="AppSubTitleColor">#D1D1D1</Color>
            <Color x:Key="AppButtonBorder">White</Color>
            <Color x:Key="AppEntryTextColor">White</Color>
            <Color x:Key="AppEntryLineColor">White</Color>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
