<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AntHiveStock.Views.ProductFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="{Binding PageTitle}"
    BackgroundColor="{DynamicResource AppBackgroundColor}">

    <ScrollView>
        <Grid Padding="24" RowDefinitions="Auto,Auto,Auto" RowSpacing="20">
            <VerticalStackLayout Spacing="4">
                <Label
                    Style="{DynamicResource InventoryTitleLabelStyle}"
                    Text="{Binding PageTitle}"
                    TextColor="{DynamicResource AppTextColor}" />
                <Label
                    Style="{DynamicResource InventorySubtitleLabelStyle}"
                    Text="Captura los datos principales del producto."
                    TextColor="{DynamicResource AppSubTitleColor}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="1" Spacing="12">
                <Label Style="{DynamicResource InventoryHeaderLabelStyle}" Text="Nombre" />
                <Entry
                    Placeholder="Ej. Monitor 24 pulgadas"
                    Style="{DynamicResource InventoryEntryStyle}"
                    Text="{Binding Name}" />

                <Label Style="{DynamicResource InventoryHeaderLabelStyle}" Text="Cantidad" />
                <Entry
                    Keyboard="Numeric"
                    Placeholder="0"
                    Style="{DynamicResource InventoryEntryStyle}"
                    Text="{Binding Quantity}" />

                <Label Style="{DynamicResource InventoryHeaderLabelStyle}" Text="Precio" />
                <Entry
                    Keyboard="Numeric"
                    Placeholder="0.00"
                    Style="{DynamicResource InventoryEntryStyle}"
                    Text="{Binding Price}" />

                <Label Style="{DynamicResource InventoryHeaderLabelStyle}" Text="Imagen" />
                <Grid ColumnDefinitions="96,*" ColumnSpacing="12">
                    <Border
                        BackgroundColor="{DynamicResource AppBackgroundColor}"
                        HeightRequest="96"
                        Stroke="{DynamicResource AppSubTitleColor}"
                        StrokeShape="RoundRectangle 8"
                        WidthRequest="96">
                        <Image
                            Aspect="AspectFill"
                            Source="{Binding ProductImageSource}" />
                    </Border>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="8"
                        VerticalOptions="Center">
                        <Button
                            Command="{Binding PickProductImageCommand}"
                            Style="{DynamicResource SecondaryInventoryButtonStyle}"
                            Text="Agregar imagen" />
                        <Label
                            Style="{DynamicResource InventorySubtitleLabelStyle}"
                            Text="{Binding ImageMessage}" />
                    </VerticalStackLayout>
                </Grid>

                <Label
                    Style="{DynamicResource InventoryValidationLabelStyle}"
                    Text="{Binding ValidationMessage}" />
            </VerticalStackLayout>

            <Grid
                Grid.Row="2"
                ColumnDefinitions="*,*"
                ColumnSpacing="8">
                <Button
                    Command="{Binding CancelCommand}"
                    Style="{DynamicResource SecondaryInventoryButtonStyle}"
                    Text="Cancelar" />
                <Button
                    Grid.Column="1"
                    Command="{Binding SaveCommand}"
                    Text="Guardar" />
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
