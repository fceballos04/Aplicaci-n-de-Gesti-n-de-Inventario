<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AntHiveStock.Views.SettingsPage"
             Title="Ajustes"
             BackgroundColor="{DynamicResource AppBackgroundColor}">

    <VerticalStackLayout Padding="24" Spacing="20">
        <VerticalStackLayout Spacing="4">
            <Label Text="Ajustes" FontSize="28" FontAttributes="Bold" TextColor="{DynamicResource AppTextColor}"/>
            <Label Text="Configura la apariencia de AntHive Stock" FontSize="14" TextColor="{DynamicResource AppSubTitleColor}"/>
        </VerticalStackLayout>

        <Border StrokeShape="RoundRectangle 12" 
                BackgroundColor="{DynamicResource AppCardColor}" 
                Padding="15" 
                StrokeThickness="1" 
                Stroke="{DynamicResource AppBorderColor}">

            <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                    <Label Text="Tema de la aplicación" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource AppTextColor}"/>
                    <Label Text="Alternar entre modo claro y oscuro" FontSize="12" TextColor="{DynamicResource AppSubTitleColor}"/>
                </VerticalStackLayout>

                <Switch Grid.Column="1" 
                        x:Name="ThemeSwitch"
                        Toggled="OnThemeToggled"
                        VerticalOptions="Center" />
            </Grid>
        </Border>
    </VerticalStackLayout>
</ContentPage>